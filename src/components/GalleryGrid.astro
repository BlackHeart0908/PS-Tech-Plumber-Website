---
import fs from 'fs';
import path from 'path';

interface Props {
  filter?: string;
  limit?: number;
}

const { filter, limit } = Astro.props;
const visibleLimit = limit ?? 8;
const allowedCategories = ['plumbing', 'electrical', 'interior'];

// Build gallery items server-side from public/images to ensure all images show.
function listFiles(dir) {
  try {
    return fs.readdirSync(dir).filter((f) => {
      const ext = path.extname(f).toLowerCase();
      return ['.jpg', '.jpeg', '.png', '.jfif', '.webp', '.gif'].includes(ext);
    });
  } catch {
    return [];
  }
}

const publicImages = path.join(process.cwd(), 'public', 'images');
const generated = [];
let idCounter = 1;

for (const cat of allowedCategories) {
  const dir = path.join(publicImages, cat);
  const files = listFiles(dir);
  for (const file of files) {
    generated.push({
      id: `${cat}-${idCounter++}`,
      file: `/images/${cat}/${encodeURIComponent(file)}`,
      alt: `${cat} project photo`,
      category: cat,
      title: `${cat} project`,
    });
  }
}

// include top-level images (pop-ceiling etc.)
const topFiles = listFiles(publicImages);
for (const file of topFiles) {
  generated.push({
    id: `top-${idCounter++}`,
    file: `/images/${encodeURIComponent(file)}`,
    alt: `site image`,
    category: 'pop',
    title: file,
  });
}

const items = filter
  ? generated.filter((g) => g.category === filter)
  : generated.filter((g) => allowedCategories.includes(g.category) || g.category === 'pop');

const hasMore = !filter && items.length > visibleLimit;
---

<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4" id="gallery-grid">
  {items.map((item, index) => {
    const hidden = !filter && index >= visibleLimit;
    return (
      <div
        class="gallery-item group relative aspect-square rounded-2xl overflow-hidden bg-sky-light border border-slate-200 cursor-pointer"
        data-category={item.category}
        data-hidden={hidden ? 'true' : 'false'}
        style={hidden ? 'display:none' : ''}
      >
        <img
          src={item.file}
          alt={item.alt}
          width="400"
          height="400"
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
        />
        <div
          class="absolute inset-0 items-center justify-center flex-col text-center p-4 hidden"
          aria-hidden="true"
        >
          <div class="text-4xl mb-2">
            {item.category === 'plumbing' ? '🔧' : item.category === 'electrical' ? '⚡' : item.category === 'interior' ? '🏠' : '🏗️'}
          </div>
          <p class="text-xs text-slate-500 font-medium">{item.title}</p>
        </div>
        <div class="absolute inset-0 bg-navy/80 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
          <p class="text-white text-sm font-heading font-semibold">{item.title}</p>
        </div>
      </div>
    );
  })}
</div>

{hasMore && (
  <div class="mt-8 text-center">
    <button
      id="gallery-view-more"
      class="inline-flex items-center justify-center rounded-full bg-azure px-8 py-3 text-sm font-semibold text-white shadow-lg shadow-azure/20 transition hover:bg-sky"
      type="button"
    >
      View More Work
    </button>
  </div>
)}

{!filter && (
  <script>
    const viewMoreButton = document.getElementById('gallery-view-more');
    if (viewMoreButton) {
      viewMoreButton.addEventListener('click', () => {
        document.querySelectorAll('.gallery-item[data-hidden="true"]').forEach((el) => {
          // cast to HTMLElement so `style` and `dataset` are available in TS checks
          const item = /** @type {HTMLElement} */ (el);
          item.style.display = '';
          item.dataset.hidden = 'false';
        });
        (/** @type {HTMLElement} */ (viewMoreButton)).style.display = 'none';
      });
    }
  </script>
)}