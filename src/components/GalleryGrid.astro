---
import { galleryItems, categories } from '../data/gallery.js';

interface Props {
  filter?: string;
  limit?: number;
}

const { filter, limit } = Astro.props;

const items = filter
  ? galleryItems.filter((g) => g.category === filter)
  : limit
  ? galleryItems.slice(0, limit)
  : galleryItems;
---

{!filter && (
  <!-- Category filter tabs — JS-driven -->
  <div class="flex flex-wrap gap-2 justify-center mb-8" id="gallery-filters">
    {categories.map((cat) => (
      <button
        data-filter={cat.id}
        class={`gallery-filter-btn px-5 py-2 rounded-full text-sm font-medium border transition-colors ${
          cat.id === 'all'
            ? 'bg-azure text-white border-azure'
            : 'bg-white text-slate-600 border-slate-200 hover:border-azure hover:text-azure'
        }`}
      >
        {cat.label}
      </button>
    ))}
  </div>
)}

<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4" id="gallery-grid">
  {items.map((item) => (
    <div
      class="gallery-item group relative aspect-square rounded-2xl overflow-hidden bg-sky-light border border-slate-200 cursor-pointer"
      data-category={item.category}
    >
      <!-- Placeholder — replace src with real image path when photos arrive -->
      <img
        src={item.file}
        alt={item.alt}
        width="400"
        height="400"
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
      />
      <!-- Fallback placeholder when image is missing -->
      <div
        class="absolute inset-0 items-center justify-center flex-col text-center p-4 hidden"
        aria-hidden="true"
      >
        <div class="text-4xl mb-2">
          {item.category === 'plumbing' ? '🔧' : item.category === 'electrical' ? '⚡' : item.category === 'interior' ? '🏠' : '🏗️'}
        </div>
        <p class="text-xs text-slate-500 font-medium">{item.title}</p>
      </div>
      <!-- Hover overlay -->
      <div class="absolute inset-0 bg-navy/80 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
        <p class="text-white text-sm font-heading font-semibold">{item.title}</p>
      </div>
    </div>
  ))}
</div>

{!filter && (
  <script>
    const btns = document.querySelectorAll<HTMLButtonElement>('.gallery-filter-btn');
    const items = document.querySelectorAll<HTMLElement>('.gallery-item');

    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;

        btns.forEach((b) => {
          b.classList.toggle('bg-azure', b === btn);
          b.classList.toggle('text-white', b === btn);
          b.classList.toggle('border-azure', b === btn);
          b.classList.toggle('bg-white', b !== btn);
          b.classList.toggle('text-slate-600', b !== btn);
          b.classList.toggle('border-slate-200', b !== btn);
        });

        items.forEach((item) => {
          const visible = filter === 'all' || item.dataset.category === filter;
          item.style.display = visible ? '' : 'none';
        });
      });
    });
  </script>
)}
