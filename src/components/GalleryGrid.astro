---
import { galleryItems } from '../data/gallery.js';

interface Props {
  filter?: string;
  limit?: number;
}

const { filter, limit } = Astro.props;
const visibleLimit = limit ?? 8;
const allowedCategories = ['plumbing', 'electrical', 'interior'];

const items = filter
  ? galleryItems.filter((g) => g.category === filter)
  : galleryItems.filter((g) => allowedCategories.includes(g.category) || g.category === 'pop');

const hasMore = !filter && items.length > visibleLimit;
---

<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4" id="gallery-grid">
  {items.map((item, index) => {
    const hidden = !filter && index >= visibleLimit;
    return (
      <div
        class="gallery-item group relative aspect-square rounded-2xl overflow-hidden bg-sky-light border border-slate-200 cursor-pointer"
        data-category={item.category}
        data-hidden={hidden ? 'true' : 'false'}
        style={hidden ? 'display:none' : ''}
      >
        <img
          src={item.file}
          alt={item.alt}
          width="400"
          height="400"
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
        />
        <div
          class="absolute inset-0 items-center justify-center flex-col text-center p-4 hidden"
          aria-hidden="true"
        >
          <div class="text-4xl mb-2">
            {item.category === 'plumbing' ? '🔧' : item.category === 'electrical' ? '⚡' : item.category === 'interior' ? '🏠' : '🏗️'}
          </div>
          <p class="text-xs text-slate-500 font-medium">{item.title}</p>
        </div>
        <div class="absolute inset-0 bg-navy/80 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
          <p class="text-white text-sm font-heading font-semibold">{item.title}</p>
        </div>
      </div>
    );
  })}
</div>

{hasMore && (
  <div class="mt-8 text-center">
    <button
      id="gallery-view-more"
      class="inline-flex items-center justify-center rounded-full bg-azure px-8 py-3 text-sm font-semibold text-white shadow-lg shadow-azure/20 transition hover:bg-sky"
      type="button"
    >
      View More Work
    </button>
  </div>
)}

{!filter && (
  <script>
    const viewMoreButton = document.getElementById('gallery-view-more');
    if (viewMoreButton) {
      viewMoreButton.addEventListener('click', () => {
        document.querySelectorAll('.gallery-item[data-hidden="true"]').forEach((el) => {
          // cast to HTMLElement so `style` and `dataset` are available in TS checks
          const item = /** @type {HTMLElement} */ (el);
          item.style.display = '';
          item.dataset.hidden = 'false';
        });
        (/** @type {HTMLElement} */ (viewMoreButton)).style.display = 'none';
      });
    }
  </script>
)}