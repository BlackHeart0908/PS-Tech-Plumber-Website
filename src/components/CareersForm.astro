---
// Form posts to /api/careers (Cloudflare Pages Function)
---

<form
  id="careers-form"
  action="/api/careers"
  method="POST"
  class="space-y-5"
  novalidate
>
  <!-- Honeypot -->
  <input type="text" name="_hp" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="car-name" class="block text-sm font-medium text-navy mb-1.5">Full Name <span class="text-red-500">*</span></label>
      <input id="car-name" name="name" type="text" required autocomplete="name"
        class="w-full border border-slate-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-azure transition"
        placeholder="Your full name" />
    </div>
    <div>
      <label for="car-phone" class="block text-sm font-medium text-navy mb-1.5">Phone Number <span class="text-red-500">*</span></label>
      <input id="car-phone" name="phone" type="tel" required autocomplete="tel" pattern="[6-9][0-9]{9}"
        class="w-full border border-slate-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-azure transition"
        placeholder="98765 43210" />
    </div>
  </div>

  <div>
    <label for="car-role" class="block text-sm font-medium text-navy mb-1.5">Role Applying For <span class="text-red-500">*</span></label>
    <select id="car-role" name="role" required
      class="w-full border border-slate-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-azure transition bg-white">
      <option value="">Select a role…</option>
      <option value="plumber">Plumber</option>
      <option value="plumber-helper">Plumber's Helper</option>
      <option value="electrician">Electrician</option>
      <option value="electrician-helper">Electrician's Helper</option>
      <option value="interior-worker">Interior / Finishing Worker</option>
      <option value="pop-worker">POP / False Ceiling Worker</option>
      <option value="supervisor">Site Supervisor</option>
      <option value="other">Other</option>
    </select>
  </div>

  <div>
    <label for="car-experience" class="block text-sm font-medium text-navy mb-1.5">Years of Experience</label>
    <select id="car-experience" name="experience"
      class="w-full border border-slate-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-azure transition bg-white">
      <option value="fresher">Fresher (looking to learn)</option>
      <option value="1-2">1–2 years</option>
      <option value="3-5">3–5 years</option>
      <option value="5+">5+ years</option>
    </select>
  </div>

  <div>
    <label for="car-message" class="block text-sm font-medium text-navy mb-1.5">Brief intro & availability</label>
    <textarea id="car-message" name="message" rows="4"
      class="w-full border border-slate-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-azure transition resize-none"
      placeholder="Tell us a bit about your skills, where you're based in Indore, and when you can start…"></textarea>
  </div>

  <button type="submit"
    class="w-full bg-azure hover:bg-sky text-white font-heading font-bold py-4 rounded-xl transition-colors text-base"
    data-track="careers-form-submit">
    Submit Application
  </button>

  <div id="car-success" class="hidden bg-green-50 border border-green-200 text-green-800 rounded-xl p-4 text-sm text-center">
    Application received! We'll be in touch within 2 working days.
  </div>
  <div id="car-error" class="hidden bg-red-50 border border-red-200 text-red-800 rounded-xl p-4 text-sm text-center">
    Something went wrong. Please WhatsApp your details to <a href="https://wa.me/919119943168" class="font-bold underline">+91 91199 43168</a>.
  </div>
</form>

<script>
  const form = document.getElementById('careers-form') as HTMLFormElement | null;
  const success = document.getElementById('car-success');
  const error = document.getElementById('car-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    if (data.get('_hp')) return;

    try {
      const res = await fetch('/api/careers', { method: 'POST', body: data });
      if (res.ok) {
        form.reset();
        success?.classList.remove('hidden');
        error?.classList.add('hidden');
      } else {
        error?.classList.remove('hidden');
        success?.classList.add('hidden');
      }
    } catch {
      error?.classList.remove('hidden');
    }
  });
</script>
