---
interface Props {
  author: string;
  rating: number;
  date: string;
  text: string;
}

const { author, rating, date, text } = Astro.props;
const stars = Array.from({ length: 5 }, (_, i) => i < rating);
---

<div
  class="bg-white rounded-2xl p-6 shadow-md border border-slate-100 flex flex-col testimonial-card"
  itemscope
  itemtype="https://schema.org/Review"
>
  <!-- Stars -->
  <div class="flex gap-0.5 mb-3" aria-label={`${rating} out of 5 stars`}>
    {stars.map((filled) => (
      <svg
        class={`w-4 h-4 ${filled ? 'text-amber' : 'text-slate-200'}`}
        fill="currentColor"
        viewBox="0 0 20 20"
        aria-hidden="true"
      >
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
      </svg>
    ))}
  </div>

  <!-- Review text -->
  <div class="flex-1 flex flex-col items-start">
    <p class="text-slate-700 text-sm leading-relaxed review-text line-clamp-4 transition-all duration-300" itemprop="reviewBody">
      "{text}"
    </p>
    {text.length > 100 && (
      <button type="button" class="text-azure text-xs font-semibold mt-2 hover:underline read-more-btn cursor-pointer">
        Read full review
      </button>
    )}
  </div>

  <!-- Attribution -->
  <div class="flex items-center justify-between mt-4 pt-4 border-t border-slate-100">
    <div>
      <p class="font-heading font-semibold text-navy text-sm" itemprop="author">{author}</p>
      <p class="text-xs text-slate-400">{date}</p>
    </div>
    <!-- Google badge -->
    <div class="flex items-center gap-1.5 text-xs text-slate-400">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      <span>Google Review</span>
    </div>
  </div>
</div>

<script>
  // Add an event listener to all read-more buttons across testimonial cards
  document.querySelectorAll('.testimonial-card').forEach(card => {
    const btn = card.querySelector('.read-more-btn');
    const text = card.querySelector('.review-text');
    if (btn && text) {
      btn.addEventListener('click', () => {
        text.classList.toggle('line-clamp-4');
        if (text.classList.contains('line-clamp-4')) {
          btn.textContent = 'Read full review';
        } else {
          btn.textContent = 'Show less';
        }
      });
    }
  });
</script>
