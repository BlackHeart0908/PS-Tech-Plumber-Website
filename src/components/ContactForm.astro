---
// Form posts to Cloudflare Pages Function at /api/contact
// Honeypot field (_hp) catches bots without CAPTCHA friction
---

<form
  id="contact-form"
  action="/api/contact"
  method="POST"
  class="space-y-5"
  novalidate
>
  <!-- Honeypot — hidden from real users, bots fill it -->
  <input type="text" name="_hp" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="cf-name" class="block text-sm font-medium text-navy mb-1.5">Your Name <span class="text-red-500">*</span></label>
      <input
        id="cf-name"
        name="name"
        type="text"
        required
        autocomplete="name"
        class="w-full border border-slate-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-azure focus:border-transparent transition"
        placeholder="Rahul Sharma"
      />
    </div>
    <div>
      <label for="cf-phone" class="block text-sm font-medium text-navy mb-1.5">Phone Number <span class="text-red-500">*</span></label>
      <input
        id="cf-phone"
        name="phone"
        type="tel"
        required
        autocomplete="tel"
        pattern="[6-9][0-9]{9}"
        class="w-full border border-slate-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-azure focus:border-transparent transition"
        placeholder="98765 43210"
      />
    </div>
  </div>

  <div>
    <label for="cf-service" class="block text-sm font-medium text-navy mb-1.5">Service Required</label>
    <select
      id="cf-service"
      name="service"
      class="w-full border border-slate-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-azure focus:border-transparent transition bg-white"
    >
      <option value="">Select a service…</option>
      <option value="plumbing">Plumbing</option>
      <option value="geyser">Geyser Repair / Installation</option>
      <option value="drain">Drain / Sewer Cleaning</option>
      <option value="water-tank">Water Tank</option>
      <option value="electrical">Electrical</option>
      <option value="interior">Interior Design</option>
      <option value="pop">POP / False Ceiling</option>
      <option value="other">Other / Not Sure</option>
    </select>
  </div>

  <div>
    <label for="cf-message" class="block text-sm font-medium text-navy mb-1.5">Tell us about the problem</label>
    <textarea
      id="cf-message"
      name="message"
      rows="4"
      class="w-full border border-slate-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-azure focus:border-transparent transition resize-none"
      placeholder="Describe the issue, your address in Indore, and preferred time…"
    ></textarea>
  </div>

  <button
    type="submit"
    class="w-full bg-azure hover:bg-sky text-white font-heading font-bold py-4 rounded-xl transition-colors text-base"
    data-track="contact-form-submit"
  >
    Send Message — We'll Call Back
  </button>

  <p class="text-xs text-slate-400 text-center">We respond within 30 minutes during business hours.</p>

  <!-- Status messages (shown by JS) -->
  <div id="cf-success" class="hidden bg-green-50 border border-green-200 text-green-800 rounded-xl p-4 text-sm text-center">
    Message sent! Our team will call you back shortly.
  </div>
  <div id="cf-error" class="hidden bg-red-50 border border-red-200 text-red-800 rounded-xl p-4 text-sm text-center">
    Something went wrong. Please call us directly at <a href="tel:+919119943168" class="font-bold underline">+91 91199 43168</a>.
  </div>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('cf-success');
  const error = document.getElementById('cf-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    // Client-side honeypot check
    if (data.get('_hp')) return;

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: data,
      });
      if (res.ok) {
        form.reset();
        success?.classList.remove('hidden');
        error?.classList.add('hidden');
      } else {
        error?.classList.remove('hidden');
        success?.classList.add('hidden');
      }
    } catch {
      error?.classList.remove('hidden');
    }
  });
</script>
