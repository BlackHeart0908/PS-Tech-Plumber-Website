---
interface Props {
  title: string;
  tagline: string;
  icon?: string;
  image?: string;
  shortDesc: string;
  slug?: string;
  points?: string[];
  moreHref?: string;
  featured?: boolean;
}

const {
  title,
  tagline,
  icon,
  image,
  shortDesc,
  slug,
  points = [],
  moreHref,
  featured = false,
} = Astro.props;

const detailsLink = moreHref ?? slug;
---

<div
  class={`group block h-full rounded-2xl border transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-azure/20 ${
    featured
      ? 'bg-gradient-to-br from-azure to-sky border-azure/30 text-white'
      : 'bg-white border-slate-200 hover:border-azure/40 text-navy'
  }`}
>
  <div class="p-7 flex flex-col h-full">
    {image ? (
      <img src={image} alt={title} class="w-16 h-16 object-cover rounded-xl mb-4 shadow-sm" />
    ) : (
      <div class={`text-4xl mb-4`}>{icon}</div>
    )}
    <h3 class={`font-heading font-bold text-xl mb-1 group-hover:text-azure transition-colors ${featured ? 'text-white group-hover:text-white' : ''}`}>
      {title}
    </h3>
    <p class={`text-sm font-medium mb-3 ${featured ? 'text-white/70' : 'text-azure'}`}>{tagline}</p>
    <p class={`text-sm leading-relaxed ${featured ? 'text-white/80' : 'text-slate-600'}`}>{shortDesc}</p>

    {points.length > 0 && (
      <ul class={
        `mt-5 space-y-2 text-sm leading-relaxed ${featured ? 'text-white/80' : 'text-slate-600'}`
      }>
        {points.map((point) => (
          <li class="flex gap-2">
            <span class="text-azure font-semibold">•</span>
            <span>{point}</span>
          </li>
        ))}
      </ul>
    )}

    {points.length > 0 && detailsLink && (
      <a
        href={detailsLink}
        class={
          `mt-6 inline-flex items-center gap-2 font-semibold text-sm ${featured ? 'text-white/90' : 'text-azure'} hover:underline`
        }
      >
        + more →
      </a>
    )}
  </div>
</div>
