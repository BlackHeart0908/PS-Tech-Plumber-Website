---
import business from '../data/business.json';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  // schema can be any valid JSON-LD object or array — loosen typing to avoid errors
  schema?: any;
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = business.heroImageUrl,
  schema,
  noindex = false,
} = Astro.props;

const canonicalURL = canonical
  ? `https://${business.domain}${canonical}`
  : Astro.url.href;

// Build JSON-LD array — global LocalBusiness schema always included
const globalSchema = {
  '@context': 'https://schema.org',
  '@type': 'PlumbingService',
  'name': business.name,
  'image': business.heroImageUrl, // TODO: CONFIRM AGAINST LIVE GBP
  '@id': business.gbpId,          // TODO: CONFIRM AGAINST LIVE GBP
  'url': `https://${business.domain}`, // TODO: CONFIRM FINAL DOMAIN
  'telephone': business.phone,    // TODO: VERIFY PHONE FORMAT WITH GBP
  'address': {
    '@type': 'PostalAddress',
    'streetAddress': business.address.street,
    'addressLocality': business.address.city,
    'addressRegion': business.address.region,
    'postalCode': business.address.postalCode,
    'addressCountry': business.address.country,
  },
  'geo': {
    '@type': 'GeoCoordinates',
    'latitude': business.geoLat,    // TODO: CONFIRM AGAINST LIVE GBP
    'longitude': business.geoLong,  // TODO: CONFIRM AGAINST LIVE GBP
  },
  'areaServed': business.serviceAreas.map((a) => ({
    '@type': 'AdministrativeArea',
    'name': `${a}, Indore`,
  })),
  'aggregateRating': {
    '@type': 'AggregateRating',
    'ratingValue': business.rating,
    'reviewCount': business.reviewCount,
  },
  'openingHours': business.openingHours, // TODO: VERIFY HOURS WITH GBP
  'priceRange': business.priceRange,
};

const sitewideBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    {
      '@type': 'ListItem',
      'position': 1,
      'name': 'Home',
      'item': `https://${business.domain}/`,
    },
  ],
};

const schemas = [globalSchema, sitewideBreadcrumb];
if (schema) {
  if (Array.isArray(schema)) schemas.push(...schema);
  else schemas.push(schema);
}
---

<!-- Primary Meta -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content="en_IN" />
<meta property="og:site_name" content={business.name} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- JSON-LD Schemas -->
{schemas.map((s) => (
  <script type="application/ld+json" set:html={JSON.stringify(s)} />
))}
