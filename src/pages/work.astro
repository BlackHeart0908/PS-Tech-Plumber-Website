---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import CTABand from '../components/CTABand.astro';

const title = 'Our Work | Plumbing & Home Services Portfolio – PS Tech Indore';
const description =
  'Browse PS Tech\'s completed plumbing, electrical, interior design, and POP false ceiling projects across Indore. Real photos, real results.';
---

<BaseLayout title={title} description={description} canonical="/work">
  <div class="bg-sky-light py-14 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <Breadcrumb crumbs={[{ label: 'Our Work' }]} />
      <h1 class="font-heading font-bold text-4xl sm:text-5xl text-navy mt-5 mb-3">
        Our Work Across Indore
      </h1>
      <p class="text-slate-600 text-xl max-w-2xl">
        Real projects. Real homes. Real results — across Vijay Nagar, Nipania, Palasia, and all of Indore.
      </p>
    </div>
  </div>

  <section class="py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <GalleryGrid />

      <!-- Placeholder notice until real photos arrive -->
      <div class="mt-12 bg-amber/10 border border-amber/30 rounded-2xl p-6 text-center">
        <p class="text-amber-dark font-heading font-semibold text-lg mb-2">📸 Real photos coming soon!</p>
        <p class="text-slate-600 text-sm">
          We're assembling our project gallery. In the meantime, call us at
          <a href="tel:+919119943168" class="text-azure font-medium">+91 91199 43168</a> to
          see before/after photos via WhatsApp, or check our Google reviews for client feedback.
        </p>
      </div>
    </div>
  </section>

  <CTABand headline="Want work like this in your home? Call PS Tech today." />
</BaseLayout>
