---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABand from '../../components/CTABand.astro';
import { services } from '../../data/services.js';
import business from '../../data/business.json';

const svc = services.find((s) => s.id === 'electrical')!;

const title = 'Electrician in Indore | Electrical Services – PS Tech';
const description =
  'Certified electrical services in Indore — wiring, panel installation, fan & light fitting, short circuit repair, safety audit. Call PS Tech: +91 91199 43168.';
---

<BaseLayout title={title} description={description} canonical="/services/electrical">
  <div class="bg-gradient-to-br from-navy to-amber/80 py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <Breadcrumb crumbs={[{ label: 'Services', href: '/services' }, { label: 'Electrical' }]} />
      <div class="mt-6 max-w-3xl">
        <div class="text-5xl mb-4">⚡</div>
        <h1 class="font-heading font-bold text-4xl sm:text-5xl text-white mb-4">
          Electrical Services in Indore
        </h1>
        <p class="text-sky-light/80 text-xl mb-6">
          Safe, reliable, certified electrical work for Indore homes and businesses. From wiring to panel upgrades, our experienced electricians get it right the first time.
        </p>
        <a
          href={`tel:${business.phoneRaw}`}
          class="inline-flex items-center gap-2 bg-amber hover:bg-amber-dark text-navy font-heading font-bold px-7 py-3.5 rounded-xl transition-colors"
        >
          Call {business.phone}
        </a>
      </div>
    </div>
  </div>

  <section class="py-16 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto prose prose-slate prose-lg">
    <h2>Trusted Electricians for Indore Homes & Offices</h2>
    <p>
      Electrical faults are a leading cause of house fires in India. PS Tech's electrical team takes safety seriously — we follow IS standards for all wiring work, install proper earthing, and use quality-rated components. Whether you're renovating a home in Palasia, fitting out a new office, or dealing with a short circuit at night, we respond fast and fix it properly.
    </p>
    <p>
      Our electricians are trained to handle both old-style round-pin British wiring common in Indore's older homes and modern modular wiring systems in new apartments. We also offer home electrical safety audits — a must-have before monsoon.
    </p>
  </section>

  <section class="pb-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {svc.groups.map((group) => (
          <div class="bg-sky-light rounded-2xl p-7 border border-azure/10" data-reveal>
            <h3 class="font-heading font-bold text-navy text-xl mb-5 pb-3 border-b border-azure/20">{group.name}</h3>
            <ul class="space-y-3">
              {group.items.map((item) => (
                <li class="flex items-center gap-3 text-slate-700 text-sm">
                  <svg class="w-4 h-4 text-amber shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABand headline="Electrical problem in Indore? Call a certified electrician now." />
</BaseLayout>
