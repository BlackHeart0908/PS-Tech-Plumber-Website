---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABand from '../../components/CTABand.astro';
import { services } from '../../data/services.js';
import business from '../../data/business.json';

const svc = services.find((s) => s.id === 'pop-work')!;

const title = 'POP False Ceiling Indore | Gypsum Ceiling Work – PS Tech';
const description =
  'Expert POP false ceiling, gypsum board ceiling, cornice work, and decorative plaster in Indore. Quality materials, neat finish, competitive rates. Call PS Tech.';
---

<BaseLayout title={title} description={description} canonical="/services/pop-work">
  <div class="bg-gradient-to-br from-sky to-azure py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <Breadcrumb crumbs={[{ label: 'Services', href: '/services' }, { label: 'POP & False Ceiling' }]} />
      <div class="mt-6 max-w-3xl">
        <div class="text-5xl mb-4">🏗️</div>
        <h1 class="font-heading font-bold text-4xl sm:text-5xl text-white mb-4">
          POP & False Ceiling Work in Indore
        </h1>
        <p class="text-sky-light/80 text-xl mb-6">
          Transform bare RCC ceilings into elegant, modern interiors with PS Tech's POP and gypsum false ceiling services. Design-led, expertly finished, and competitively priced across Indore.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 bg-amber hover:bg-amber-dark text-navy font-heading font-bold px-7 py-3.5 rounded-xl transition-colors"
        >
          Get a Free Quote
        </a>
      </div>
    </div>
  </div>

  <section class="py-16 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto prose prose-slate prose-lg">
    <h2>POP vs. Gypsum — Which False Ceiling Is Right for Your Indore Home?</h2>
    <p>
      POP (Plaster of Paris) and gypsum board are both excellent false ceiling materials, each with different strengths. POP is highly customisable — ideal for curved, layered, or sculptural designs, and for traditional cornice and border work. Gypsum board is lighter, faster to install, and better suited to straight-edged modern ceilings and commercial grid systems. Our blog post <a href="/blog/pop-ceiling-vs-gypsum-indore">POP False Ceiling vs Gypsum: Which Is Right for Your Indore Home?</a> goes deeper on this.
    </p>
    <p>
      PS Tech's team is experienced with both systems. We handle the complete workflow: ceiling design consultation, material procurement, installation, LED cove integration, and a smooth finish coat. Most rooms are completed in 1–3 days depending on complexity.
    </p>
  </section>

  <section class="pb-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {svc.groups.map((group) => (
          <div class="bg-sky-light rounded-2xl p-7 border border-azure/10" data-reveal>
            <h3 class="font-heading font-bold text-navy text-xl mb-5 pb-3 border-b border-azure/20">{group.name}</h3>
            <ul class="space-y-3">
              {group.items.map((item) => (
                <li class="flex items-center gap-3 text-slate-700 text-sm">
                  <svg class="w-4 h-4 text-sky shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABand headline="Get a free POP ceiling estimate in Indore." subtext="Home visit · Design sketch · No-obligation quote" />
</BaseLayout>
