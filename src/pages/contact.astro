---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import NAP from '../components/NAP.astro';
import MapEmbed from '../components/MapEmbed.astro';
import ContactForm from '../components/ContactForm.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import business from '../data/business.json';

const title = 'Contact PS Tech | Plumber in Indore – Call +91 91199 43168';
const description =
  'Contact PS Tech for plumbing, electrical, interior & POP services in Indore. Call +91 91199 43168, WhatsApp, or fill our online form. Same-day response.';
---

<BaseLayout title={title} description={description} canonical="/contact">
  <div class="bg-sky-light py-14 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <Breadcrumb crumbs={[{ label: 'Contact' }]} />
      <h1 class="font-heading font-bold text-4xl sm:text-5xl text-navy mt-5 mb-3">
        Contact PS Tech
      </h1>
      <p class="text-slate-600 text-xl max-w-xl">
        Get in touch for same-day plumbing, electrical, or home services anywhere in Indore.
      </p>
    </div>
  </div>

  <section class="py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- Contact info + quick actions -->
      <div>
        <h2 class="font-heading font-bold text-2xl text-navy mb-6">Get in Touch</h2>

        <!-- Quick call/whatsapp buttons -->
        <div class="flex flex-col sm:flex-row gap-4 mb-8">
          <a
            href={`tel:${business.phoneRaw}`}
            class="flex items-center justify-center gap-3 bg-azure hover:bg-sky text-white font-heading font-bold px-7 py-4 rounded-2xl transition-colors shadow-lg flex-1"
            data-track="contact-page-call"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
            Call Now
          </a>
          <a
            href={`https://wa.me/${business.whatsapp}?text=${business.whatsappMessage}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-3 bg-green-600 hover:bg-green-700 text-white font-heading font-bold px-7 py-4 rounded-2xl transition-colors shadow-lg flex-1"
            data-track="contact-page-whatsapp"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>

        <!-- NAP block -->
        <div class="bg-sky-light rounded-2xl p-6 border border-azure/10 mb-6">
          <NAP class="text-navy space-y-1.5" />
        </div>

        <!-- Hours + notes -->
        <div class="space-y-4 text-sm text-slate-600">
          <div class="flex gap-3">
            <span class="text-lg">🕐</span>
            <div>
              <strong class="text-navy">Business Hours</strong>
              <p>{business.openingHoursDisplay}</p>
              <p class="text-xs text-slate-400">Emergency line available outside hours.</p>
            </div>
          </div>
          <div class="flex gap-3">
            <span class="text-lg">⚡</span>
            <div>
              <strong class="text-navy">Response Time</strong>
              <p>Within {business.responseTime} for all Indore service areas</p>
            </div>
          </div>
          <div class="flex gap-3">
            <span class="text-lg">⭐</span>
            <div>
              <strong class="text-navy">{business.rating} Google Rating</strong>
              <a href={business.gbpReviewUrl} target="_blank" rel="noopener noreferrer" class="text-azure hover:underline">
                Read all {business.reviewCount} reviews →
              </a>
            </div>
          </div>
        </div>

        <!-- Map -->
        <div class="mt-8">
          <MapEmbed class="rounded-2xl overflow-hidden h-56 w-full" />
        </div>
      </div>

      <!-- Contact form -->
      <div>
        <h2 class="font-heading font-bold text-2xl text-navy mb-6">Send Us a Message</h2>
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-200">
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews on contact page -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-sky-light">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-heading font-bold text-2xl text-navy mb-8 text-center">
        Trusted by Indore homeowners — {business.rating}★ on Google
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {business.reviews.slice(0, 3).map((r) => (
          <TestimonialCard author={r.author} rating={r.rating} date={r.date} text={r.text} />
        ))}
      </div>
      <div class="text-center mt-8">
        <a href={business.gbpReviewUrl} target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 bg-amber hover:bg-amber-dark text-navy font-heading font-bold px-7 py-3.5 rounded-xl transition-colors">
          Read all {business.reviewCount} reviews on Google →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
