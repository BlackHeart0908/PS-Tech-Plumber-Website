---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABand from '../../components/CTABand.astro';
import { areas } from '../../data/areas.js';
import business from '../../data/business.json';

const area = areas.find((a) => a.id === 'palasia')!;
const title = `Plumber in Palasia Indore | Commercial & Residential Plumbing – PS Tech`;
const description = `Expert plumber in Palasia, Indore — commercial kitchen waste disposal, apartment geyser fitting, emergency leak repair. Call PS Tech: ${business.phone}.`;
---

<BaseLayout title={title} description={description} canonical="/service-areas/palasia">
  <div class="bg-gradient-to-br from-navy to-azure/80 py-14 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <Breadcrumb crumbs={[{ label: 'Service Areas', href: '/service-areas' }, { label: area.name }]} />
      <h1 class="font-heading font-bold text-4xl sm:text-5xl text-white mt-5 mb-3">
        Plumber in Palasia, Indore
      </h1>
      <p class="text-sky-light/80 text-xl max-w-2xl">
        Commercial and residential plumbing in the heart of Indore — waste disposal, office bathrooms, geyser fitting, and emergency response for Palasia's busy buildings.
      </p>
      <div class="flex flex-wrap gap-4 mt-6">
        <a href={`tel:${business.phoneRaw}`} class="bg-amber hover:bg-amber-dark text-navy font-heading font-bold px-7 py-3.5 rounded-xl transition-colors">
          Call {business.phone}
        </a>
        <a href={`https://wa.me/${business.whatsapp}?text=Hi%20PS%20Tech%2C%20I%20need%20a%20plumber%20in%20Palasia%20Indore.`}
           target="_blank" rel="noopener noreferrer"
           class="bg-green-600 text-white font-heading font-bold px-7 py-3.5 rounded-xl transition-colors hover:bg-green-700">
          WhatsApp for Palasia
        </a>
      </div>
    </div>
  </div>

  <article class="py-16 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto prose prose-slate prose-lg">
    <h2>Plumbing in Palasia — What We Know About This Area</h2>
    <p>{area.description}</p>

    <h2>Commercial Plumbing in Palasia</h2>
    <p>
      Restaurants, cafes, and offices in Palasia need reliable, hygienic plumbing — particularly commercial-grade kitchen sinks, waste disposal units, and grease trap connections. PS Tech handles commercial plumbing fit-outs and maintenance contracts. Fast response is especially important for food businesses where a blocked kitchen drain can mean closing for the day.
    </p>
    <ul>
      {area.commonIssues.map((issue) => <li>{issue}</li>)}
    </ul>

    <h2>Emergency Plumber in Palasia</h2>
    <p>
      Burst pipes and sudden water pressure loss in Palasia's older apartment buildings can affect multiple floors. PS Tech dispatches fast to Palasia — typically within 2 hours — because we understand the urgency and the knock-on impact on building occupants. <a href="/blog/emergency-plumbing-indore">Read what to do before the plumber arrives</a>.
    </p>
    <p><a href="/contact">Book a Palasia plumber</a> or call for emergency response.</p>
  </article>

  <CTABand headline="Plumber in Palasia — commercial & residential, we cover both." />
</BaseLayout>
