---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABand from '../../components/CTABand.astro';
import { areas } from '../../data/areas.js';
import business from '../../data/business.json';

const area = areas.find((a) => a.id === 'bhawarkuan')!;
const title = `Plumber in Bhawarkuan Indore | Water Tank & Outdoor Plumbing – PS Tech`;
const description = `Expert plumber in Bhawarkuan, Indore — water tank replacement, float valve repair, garden plumbing, society connections. Call PS Tech: ${business.phone}.`;
---

<BaseLayout title={title} description={description} canonical="/service-areas/bhawarkuan">
  <div class="bg-gradient-to-br from-navy to-azure/80 py-14 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <Breadcrumb crumbs={[{ label: 'Service Areas', href: '/service-areas' }, { label: area.name }]} />
      <h1 class="font-heading font-bold text-4xl sm:text-5xl text-white mt-5 mb-3">
        Plumber in Bhawarkuan, Indore
      </h1>
      <p class="text-sky-light/80 text-xl max-w-2xl">
        Water tank installation and upsizing, float valve repair, outdoor garden plumbing, and bungalow plumbing services across Bhawarkuan and Banganga.
      </p>
      <div class="flex flex-wrap gap-4 mt-6">
        <a href={`tel:${business.phoneRaw}`} class="bg-amber hover:bg-amber-dark text-navy font-heading font-bold px-7 py-3.5 rounded-xl transition-colors">
          Call {business.phone}
        </a>
        <a href={`https://wa.me/${business.whatsapp}?text=Hi%20PS%20Tech%2C%20I%20need%20a%20plumber%20in%20Bhawarkuan%20Indore.`}
           target="_blank" rel="noopener noreferrer"
           class="bg-green-600 text-white font-heading font-bold px-7 py-3.5 rounded-xl transition-colors hover:bg-green-700">
          WhatsApp for Bhawarkuan
        </a>
      </div>
    </div>
  </div>

  <article class="py-16 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto prose prose-slate prose-lg">
    <h2>Plumbing in Bhawarkuan — What We Know About This Area</h2>
    <p>{area.description}</p>

    <h2>Water Tank Installation in Bhawarkuan</h2>
    <p>
      Rooftop water tanks in Bhawarkuan's bungalows and societies are often the original tanks from when the property was built — undersized for today's household water use and past their UV-resistance lifespan. We supply and install HDPE tanks (Sintex, Penguin) from 500 L to 10,000 L with proper inlet float valves, overflow discharge pipes, and UV-resistant lids to prevent algae growth. We also handle tank cleaning and disinfection.
    </p>
    <ul>
      {area.commonIssues.map((issue) => <li>{issue}</li>)}
    </ul>

    <h2>Outdoor & Garden Plumbing in Bhawarkuan</h2>
    <p>
      Independent homes in Bhawarkuan often need outdoor plumbing that apartment blocks don't: garden taps with proper stopcock isolation, car-wash points with flexible hose connections, and boundary-wall water connections for separate units. PS Tech handles all outdoor plumbing neatly with UV-resistant CPVC piping and properly earthed connections for any external pump setups.
    </p>
    <p>
      Read our guide on <a href="/blog/water-tank-indore">choosing the right water tank for your Indore home</a>.
    </p>
    <p><a href="/contact">Book a Bhawarkuan plumber</a> — free estimate for tank replacement.</p>
  </article>

  <CTABand headline="Plumber in Bhawarkuan — water tanks, outdoor plumbing & more." />
</BaseLayout>
