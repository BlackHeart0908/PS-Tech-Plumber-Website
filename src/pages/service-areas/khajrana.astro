---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABand from '../../components/CTABand.astro';
import { areas } from '../../data/areas.js';
import business from '../../data/business.json';

const area = areas.find((a) => a.id === 'khajrana')!;
const title = `Plumber in Khajrana Indore | Drain Cleaning & Toilet Repair – PS Tech`;
const description = `Expert plumber in Khajrana, Indore — blocked drain cleaning, toilet fitting, sewer jetting, monsoon drain repair. Call PS Tech: ${business.phone}.`;
---

<BaseLayout title={title} description={description} canonical="/service-areas/khajrana">
  <div class="bg-gradient-to-br from-navy to-azure/80 py-14 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <Breadcrumb crumbs={[{ label: 'Service Areas', href: '/service-areas' }, { label: area.name }]} />
      <h1 class="font-heading font-bold text-4xl sm:text-5xl text-white mt-5 mb-3">
        Plumber in Khajrana, Indore
      </h1>
      <p class="text-sky-light/80 text-xl max-w-2xl">
        Drain jetting, sewer repair, toilet fitting, and monsoon drain protection for Khajrana's dense residential and commercial areas.
      </p>
      <div class="flex flex-wrap gap-4 mt-6">
        <a href={`tel:${business.phoneRaw}`} class="bg-amber hover:bg-amber-dark text-navy font-heading font-bold px-7 py-3.5 rounded-xl transition-colors">
          Call {business.phone}
        </a>
        <a href={`https://wa.me/${business.whatsapp}?text=Hi%20PS%20Tech%2C%20I%20need%20a%20plumber%20in%20Khajrana%20Indore.`}
           target="_blank" rel="noopener noreferrer"
           class="bg-green-600 text-white font-heading font-bold px-7 py-3.5 rounded-xl transition-colors hover:bg-green-700">
          WhatsApp for Khajrana
        </a>
      </div>
    </div>
  </div>

  <article class="py-16 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto prose prose-slate prose-lg">
    <h2>Plumbing in Khajrana — What We Know About This Area</h2>
    <p>{area.description}</p>

    <h2>Blocked Drains in Khajrana — The Fix That Lasts</h2>
    <p>
      Kitchen grease, sanitary waste, and monsoon silt are the main culprits for blocked drains in Khajrana. PS Tech uses high-pressure water jetting (up to 3000 PSI) to clear blockages that manual rods can't reach. We also inspect the drain after clearing to ensure no root intrusion or collapsed pipe section is causing a recurring problem.
    </p>
    <ul>
      {area.commonIssues.map((issue) => <li>{issue}</li>)}
    </ul>

    <h2>Toilet Installation & Repair in Khajrana</h2>
    <p>
      Whether you're replacing a cracked Indian squat pan, installing a modern wall-hung toilet with concealed cistern, or fixing a continuously running flush — our plumbers have the parts and skills to complete the job neatly. We serve both individual homes and small commercial properties in Khajrana and Sukhliya. Read more: <a href="/blog/drain-clogging-causes">Why Your Drain Keeps Clogging — Causes, Fixes & Prevention</a>.
    </p>
    <p><a href="/contact">Book a Khajrana plumber</a> or call for same-day availability.</p>
  </article>

  <CTABand headline="Plumber in Khajrana — blocked drains cleared fast." />
</BaseLayout>
